{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmx/claim_extract.v1.json",
  "title": "PMX Claim Extract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "market_id",
    "generated_at",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "claim_extract.v1"
    },
    "market_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/raw_claim"
      }
    },
    "canonical_claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canonical_claim"
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1,
          "maxLength": 4096
        },
        "title": {
          "type": "string",
          "maxLength": 2000
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "quote": {
          "type": "string",
          "maxLength": 4000
        },
        "source_type": {
          "type": "string",
          "enum": [
            "primary",
            "secondary",
            "unknown"
          ]
        }
      }
    },
    "raw_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_text",
        "stance",
        "sources"
      ],
      "properties": {
        "claim_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "stance": {
          "type": "string",
          "enum": [
            "support",
            "oppose",
            "neutral",
            "unknown"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    },
    "canonical_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_canonical",
        "claim_hash",
        "source_urls"
      ],
      "properties": {
        "claim_canonical": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "claim_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_urls": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "uri",
            "maxLength": 4096
          }
        },
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
