{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmx.audit_bundle.audit_bundle_artifact.v1",
  "title": "Audit Bundle Artifact v1",
  "type": "object",
  "required": [
    "artifact_schema_version",
    "run_id",
    "generated_at_utc",
    "code_version",
    "config_hash",
    "audit_bundle_policy_version",
    "params",
    "inputs",
    "timeline",
    "quality_flags",
    "quality_warnings",
    "bundle_hash",
    "audit_bundle_policy_hash",
    "audit_bundle_payload_hash"
  ],
  "properties": {
    "artifact_schema_version": {
      "type": "string",
      "const": "audit_bundle_artifact.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "code_version": {
      "type": "string",
      "minLength": 1
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "audit_bundle_policy_version": {
      "type": "string",
      "const": "audit_bundle.v1"
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event_item"
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event_item"
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "bundle_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "audit_bundle_policy_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "audit_bundle_payload_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "event_item": {
      "type": "object",
      "required": [
        "stage",
        "artifact_path",
        "payload_hash"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "generated_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "code_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "config_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "payload_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "policy_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
