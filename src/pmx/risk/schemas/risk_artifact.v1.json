{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmx.risk.risk_artifact.v1",
  "title": "Risk Artifact v1",
  "type": "object",
  "required": [
    "artifact_schema_version",
    "run_id",
    "generated_at_utc",
    "code_version",
    "config_hash",
    "input_trade_plan_artifact_hash",
    "risk_policy_version",
    "params",
    "items",
    "counts",
    "notional_summary",
    "quality_flags",
    "quality_warnings",
    "policy_hash",
    "items_hash",
    "risk_payload_hash"
  ],
  "properties": {
    "artifact_schema_version": {
      "type": "string",
      "const": "risk_artifact.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "code_version": {
      "type": "string",
      "minLength": 1
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "input_trade_plan_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "input_trade_plan_artifact_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "input_performance_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "input_performance_artifact_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "forecast_payload_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "dataset_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "model_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "calibration_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "uncertainty_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "decision_payload_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "decision_policy_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "trade_plan_payload_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "trade_plan_policy_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "risk_policy_version": {
      "type": "string",
      "const": "risk_policy.v1"
    },
    "params": {
      "type": "object",
      "required": [
        "max_total_notional_usd",
        "max_notional_per_market_usd",
        "max_notional_per_category_usd",
        "top1_share_cap",
        "top3_share_cap",
        "performance_top1_cap",
        "performance_top3_cap",
        "allow_downsize",
        "min_notional_usd"
      ],
      "properties": {
        "max_total_notional_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_notional_per_market_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_notional_per_category_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "top1_share_cap": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "top3_share_cap": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "performance_top1_cap": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "performance_top3_cap": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "allow_downsize": {
          "type": "boolean"
        },
        "min_notional_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank",
          "market_id",
          "token_id",
          "side",
          "requested_notional_usd",
          "approved_notional_usd",
          "verdict",
          "reason_codes",
          "quality_flags",
          "quality_warnings"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "market_id": {
            "type": "string",
            "minLength": 1
          },
          "token_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "side": {
            "type": "string",
            "enum": [
              "BUY_YES",
              "BUY_NO"
            ]
          },
          "requested_notional_usd": {
            "type": "number",
            "minimum": 0
          },
          "approved_notional_usd": {
            "type": "number",
            "minimum": 0
          },
          "verdict": {
            "type": "string",
            "enum": [
              "ALLOW",
              "BLOCK",
              "DOWNSIZE"
            ]
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "quality_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "quality_warnings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "code"
              ],
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 1
                },
                "message": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "counts": {
      "type": "object",
      "required": [
        "n_total",
        "n_allow",
        "n_block",
        "n_downsize"
      ],
      "properties": {
        "n_total": {
          "type": "integer",
          "minimum": 0
        },
        "n_allow": {
          "type": "integer",
          "minimum": 0
        },
        "n_block": {
          "type": "integer",
          "minimum": 0
        },
        "n_downsize": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "notional_summary": {
      "type": "object",
      "required": [
        "requested_total_usd",
        "approved_total_usd",
        "blocked_total_usd"
      ],
      "properties": {
        "requested_total_usd": {
          "type": "number",
          "minimum": 0
        },
        "approved_total_usd": {
          "type": "number",
          "minimum": 0
        },
        "blocked_total_usd": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "items_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "risk_payload_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}
