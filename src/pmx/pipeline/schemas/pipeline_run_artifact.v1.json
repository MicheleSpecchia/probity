{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmx.pipeline.pipeline_run_artifact.v1",
  "title": "Pipeline Run Artifact v1",
  "type": "object",
  "required": [
    "artifact_schema_version",
    "run_id",
    "generated_at_utc",
    "code_version",
    "config_hash",
    "pipeline_policy_version",
    "inputs",
    "outputs",
    "kpis",
    "quality_flags",
    "quality_warnings",
    "pipeline_policy_hash",
    "pipeline_outputs_hash",
    "pipeline_payload_hash"
  ],
  "properties": {
    "artifact_schema_version": {
      "type": "string",
      "const": "pipeline_run_artifact.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "code_version": {
      "type": "string",
      "minLength": 1
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pipeline_policy_version": {
      "type": "string",
      "const": "pipeline_stub.v1"
    },
    "inputs": {
      "type": "object",
      "required": [
        "forecast_artifact_path",
        "forecast_artifact_hash",
        "forecast_run_id"
      ],
      "properties": {
        "forecast_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "forecast_artifact_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "forecast_run_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "required": [
        "decision",
        "trade_plan",
        "execution",
        "portfolio"
      ],
      "properties": {
        "decision": {
          "$ref": "#/$defs/output_stage"
        },
        "trade_plan": {
          "$ref": "#/$defs/output_stage"
        },
        "execution": {
          "$ref": "#/$defs/output_stage"
        },
        "portfolio": {
          "$ref": "#/$defs/output_stage"
        }
      },
      "additionalProperties": false
    },
    "kpis": {
      "type": "object",
      "required": [
        "n_decisions",
        "n_orders",
        "n_rejected",
        "n_positions",
        "total_notional_usd",
        "unrealized_pnl_usd"
      ],
      "properties": {
        "n_decisions": {
          "type": "integer",
          "minimum": 0
        },
        "n_orders": {
          "type": "integer",
          "minimum": 0
        },
        "n_rejected": {
          "type": "integer",
          "minimum": 0
        },
        "n_positions": {
          "type": "integer",
          "minimum": 0
        },
        "total_notional_usd": {
          "type": "object",
          "required": [
            "planned",
            "executed"
          ],
          "properties": {
            "planned": {
              "type": "number",
              "minimum": 0
            },
            "executed": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "unrealized_pnl_usd": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "carry_through_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[0-9a-f]{64}$"
      }
    },
    "pipeline_policy_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pipeline_outputs_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pipeline_payload_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "output_stage": {
      "type": "object",
      "required": [
        "run_id",
        "artifact_path",
        "payload_hash"
      ],
      "properties": {
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "payload_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "policy_hash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
