{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pmx.forecast.forecast_artifact.v1",
  "title": "Forecast Artifact v1",
  "type": "object",
  "required": [
    "artifact_schema_version",
    "run_id",
    "code_version",
    "config_hash",
    "dataset_hash",
    "model_hash",
    "calibration_hash",
    "uncertainty_hash",
    "forecast_payload_hash",
    "calibration_report",
    "calibration_report_hash",
    "uncertainty_report",
    "uncertainty_report_hash",
    "quality_flags",
    "quality_warnings"
  ],
  "properties": {
    "artifact_schema_version": {
      "type": "string",
      "const": "forecast_artifact.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "code_version": {
      "type": "string",
      "minLength": 1
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "dataset_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "model_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "calibration_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "uncertainty_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "forecast_payload_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "calibration_report": {
      "type": "object"
    },
    "calibration_report_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "uncertainty_report": {
      "type": "object"
    },
    "uncertainty_report_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
