POSTGRES_USER=pmx
POSTGRES_PASSWORD=pmx_dev_password
POSTGRES_DB=pmx
APP_DATABASE_URL=postgresql+psycopg://pmx:pmx_dev_password@localhost:5432/pmx
DATABASE_URL=postgresql+psycopg://pmx:pmx_dev_password@localhost:5432/pmx

# Gamma API (catalog refresh)
# GAMMA_BASE_URL=https://gamma-api.polymarket.com
# GAMMA_TIMEOUT_SECONDS=20
# GAMMA_PAGE_SIZE=200

# CLOB REST (time-series ingestion)
# CLOB_BASE_URL=https://clob.polymarket.com
# CLOB_TIMEOUT_SECONDS=20
# CLOB_RATE_LIMIT_RPS=5
# CLOB_ORDERBOOK_DEPTH=50
# CLOB_API_KEY=
# Feature snapshots (micro_v1)
# INGEST_EPSILON_SECONDS=300

# CLOB WSS (listener + reconcile)
# CLOB_WSS_URL=wss://clob.polymarket.com/ws
# CLOB_WSS_TIMEOUT_SECONDS=20
# CLOB_WSS_MAX_RECONNECTS=8
# CLOB_WSS_BACKOFF_SECONDS=0.5
# CLOB_WSS_MAX_BACKOFF_SECONDS=30
# Precedence: CLOB_WSS_SEQ_FIELD (legacy override) > CLOB_WSS_SEQ_FIELDS.
# If CLOB_WSS_SEQ_FIELD is set to empty/whitespace, seq-based detection is disabled.
# CLOB_WSS_SEQ_FIELDS=seq,sequence,offset
# Legacy override (optional): set CLOB_WSS_SEQ_FIELD to force a single field;
# set to empty string to disable seq-based detection.
# CLOB_WSS_SEQ_FIELD=seq
# msg_id/event_id stay diagnostic-only and are not used for gap detection.
# CLOB_RECONCILE_GAP_SECONDS=60
# CLOB_RECONCILE_MISMATCH_BPS=10

# News ingestion (GDELT + whitelist crawler)
# GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
# GDELT_TIMEOUT_SECONDS=20
# GDELT_MAX_RETRIES=4
# GDELT_BACKOFF_SECONDS=0.5
# GDELT_MAX_RECORDS=250
# NEWS_PRIMARY_SOURCES_CONFIG=config/primary_sources.yaml
# NEWS_CRAWLER_CONNECT_TIMEOUT_SECONDS=5
# NEWS_CRAWLER_READ_TIMEOUT_SECONDS=15
# NEWS_CRAWLER_MAX_RETRIES=3
# NEWS_CRAWLER_BACKOFF_SECONDS=0.5
